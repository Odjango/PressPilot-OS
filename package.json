{
  "name": "presspilot-os",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "rm -rf .next && next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "worker": "npx tsx scripts/start-worker.ts",
    "demo-kits": "npm run build && tsx scripts/demo-kits.ts",
    "verify-supabase": "tsx scripts/verify-supabase.ts",
    "build-wp-theme": "tsx src/generator/index.ts",
    "theme:build": "npx tsx scripts/validateGenerator.ts golden-spec && npx tsx scripts/buildWpTheme.ts",
    "validate-theme": "node validator/presspilot-validator.js",
    "test:themes": "node scripts/generate-and-validate-test-themes.js",
    "generate": "tsx src/generator/index.ts",
    "prepare": "husky"
  },
  "bin": {
    "presspilot-validate": "validator/presspilot-validator.js"
  },
  "dependencies": {
    "@lemonsqueezy/lemonsqueezy.js": "^4.0.0",
    "@sentry/nextjs": "^10.38.0",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.91.1",
    "@types/jsdom": "^27.0.0",
    "@types/jszip": "^3.4.0",
    "@wordpress/block-library": "^9.36.0",
    "@wordpress/block-serialization-default-parser": "^5.36.0",
    "@wordpress/blocks": "^15.9.0",
    "@wordpress/data": "^10.36.0",
    "@wordpress/element": "^6.36.0",
    "@wordpress/hooks": "^4.36.0",
    "adm-zip": "^0.5.12",
    "archiver": "^7.0.1",
    "clsx": "^2.1.1",
    "colorthief": "^2.6.0",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.26",
    "fs-extra": "^11.3.3",
    "gsap": "^3.14.2",
    "jimp": "^1.6.0",
    "jsdom": "^27.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "puppeteer": "^24.36.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tinycolor2": "^1.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^20.12.12",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/tinycolor2": "^1.4.6",
    "autoprefixer": "^10.4.22",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.1.1",
    "husky": "^9.1.7",
    "jsdom-global": "^3.0.2",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5"
  }
}
