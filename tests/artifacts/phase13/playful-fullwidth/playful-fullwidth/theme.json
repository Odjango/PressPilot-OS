{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 2,
    "customTemplates": [
        {
            "name": "page-without-title",
            "title": "Page Without Title",
            "postTypes": [
                "page"
            ]
        }
    ],
    "settings": {
        "appearanceTools": true,
        "color": {
            "gradients": [
                {
                    "slug": "gradient-1",
                    "name": "Accent Fade",
                    "gradient": "linear-gradient(180deg, var(--wp--preset--color--accent) 0%, var(--wp--preset--color--accent-3) 100%)"
                },
                {
                    "slug": "gradient-2",
                    "name": "Hero Overlay",
                    "gradient": "linear-gradient(180deg, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.3) 100%)"
                },
                {
                    "slug": "gradient-3",
                    "name": "Accent Glow",
                    "gradient": "linear-gradient(135deg, var(--wp--preset--color--accent) 0%, var(--wp--preset--color--accent-5) 100%)"
                },
                {
                    "slug": "gradient-4",
                    "name": "Surface Subtle",
                    "gradient": "linear-gradient(180deg, var(--wp--preset--color--base-2) 0%, var(--wp--preset--color--base) 100%)"
                },
                {
                    "slug": "gradient-5",
                    "name": "Contrast Fade",
                    "gradient": "linear-gradient(180deg, var(--wp--preset--color--contrast) 50%, var(--wp--preset--color--base) 50%)"
                }
            ],
            "link": true,
            "palette": [
                {
                    "slug": "base",
                    "color": "#FBF4EF",
                    "name": "Base"
                },
                {
                    "slug": "base-2",
                    "color": "#FFFFFF",
                    "name": "Base / Two"
                },
                {
                    "slug": "contrast",
                    "color": "#374AC8",
                    "name": "Contrast"
                },
                {
                    "slug": "contrast-2",
                    "color": "#5a6fd6",
                    "name": "Contrast / Two"
                },
                {
                    "slug": "contrast-3",
                    "color": "#000000",
                    "name": "Contrast / Three"
                },
                {
                    "slug": "accent",
                    "color": "#FFC3CF",
                    "name": "Accent"
                },
                {
                    "slug": "accent-2",
                    "color": "#FFF3C3",
                    "name": "Accent / Two"
                },
                {
                    "slug": "accent-3",
                    "color": "#D5C3FF",
                    "name": "Accent / Three"
                },
                {
                    "slug": "accent-4",
                    "color": "#C3FFF3",
                    "name": "Accent / Four"
                },
                {
                    "slug": "accent-5",
                    "color": "#374AC8",
                    "name": "Accent / Five"
                },
                {
                    "slug": "primary",
                    "color": "#FFC3CF",
                    "name": "Primary"
                },
                {
                    "slug": "primary-light",
                    "color": "#FFF3C3",
                    "name": "Primary light"
                },
                {
                    "slug": "primary-dark",
                    "color": "#D5C3FF",
                    "name": "Primary dark"
                },
                {
                    "slug": "primary-subtle",
                    "color": "#FFF3C3",
                    "name": "Primary subtle"
                },
                {
                    "slug": "secondary",
                    "color": "#C3FFF3",
                    "name": "Secondary"
                },
                {
                    "slug": "tertiary",
                    "color": "#374AC8",
                    "name": "Tertiary"
                },
                {
                    "slug": "foreground",
                    "color": "#374AC8",
                    "name": "Foreground"
                },
                {
                    "slug": "background",
                    "color": "#FBF4EF",
                    "name": "Background"
                },
                {
                    "slug": "surface",
                    "color": "#FFFFFF",
                    "name": "Surface"
                },
                {
                    "slug": "text",
                    "color": "#374AC8",
                    "name": "Text"
                },
                {
                    "slug": "heading",
                    "color": "#374AC8",
                    "name": "Heading"
                },
                {
                    "slug": "muted",
                    "color": "#5a6fd6",
                    "name": "Muted"
                },
                {
                    "slug": "border",
                    "color": "#000000",
                    "name": "Border"
                },
                {
                    "slug": "main",
                    "color": "#374AC8",
                    "name": "Main"
                },
                {
                    "slug": "cta-bg",
                    "color": "#FFC3CF",
                    "name": "Cta bg"
                },
                {
                    "slug": "cta-text",
                    "color": "#FBF4EF",
                    "name": "Cta text"
                },
                {
                    "slug": "success",
                    "color": "#22c55e",
                    "name": "Success"
                },
                {
                    "slug": "warning",
                    "color": "#f59e0b",
                    "name": "Warning"
                },
                {
                    "slug": "error",
                    "color": "#ef4444",
                    "name": "Error"
                },
                {
                    "slug": "info",
                    "color": "#3b82f6",
                    "name": "Info"
                }
            ]
        },
        "custom": {
            "shaded-style": {
                "border": {
                    "width": "2px",
                    "style": "solid",
                    "color": "currentColor"
                },
                "box-shadow": {
                    "x": "4px",
                    "y": "4px",
                    "blur": 0,
                    "color": "currentColor"
                },
                "combined": {
                    "border": "var( --wp--custom--shaded-style--border--width ) var( --wp--custom--shaded-style--border--style ) var( --wp--custom--shaded-style--border--color )",
                    "box-shadow": "var( --wp--custom--shaded-style--box-shadow--x ) var( --wp--custom--shaded-style--box-shadow--y ) var( --wp--custom--shaded-style--box-shadow--blur ) var( --wp--custom--shaded-style--box-shadow--color )"
                }
            },
            "spacing": {
                "baseline": "16px"
            },
            "typography": {
                "letter-spacing": {
                    "gigantic": "-0.04em",
                    "heading": "-0.03em",
                    "body": "-0.01em",
                    "uppercase": "0.04em"
                },
                "line-height": {
                    "body": 1.5,
                    "heading": 1.25,
                    "gigantic": 1.05
                }
            }
        },
        "layout": {
            "contentSize": "640px",
            "wideSize": "1920px"
        },
        "spacing": {
            "blockGap": true,
            "spacingScale": {
                "steps": 0
            },
            "spacingSizes": [
                {
                    "slug": "10",
                    "name": "1",
                    "size": "1rem"
                },
                {
                    "slug": "20",
                    "name": "2",
                    "size": "min(1.5rem, 2vw)"
                },
                {
                    "slug": "30",
                    "name": "3",
                    "size": "min(2.5rem, 3vw)"
                },
                {
                    "slug": "40",
                    "name": "4",
                    "size": "min(4rem, 5vw)"
                },
                {
                    "slug": "50",
                    "name": "5",
                    "size": "min(6.5rem, 8vw)"
                },
                {
                    "slug": "60",
                    "name": "6",
                    "size": "min(10.5rem, 13vw)"
                }
            ],
            "units": [
                "%",
                "em",
                "px",
                "rem",
                "vh",
                "vw"
            ],
            "padding": true,
            "margin": true
        },
        "typography": {
            "customFontSize": true,
            "fluid": true,
            "fontFamilies": [
                {
                    "fontFamily": "\"DM Sans\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", sans-serif",
                    "slug": "dm-sans",
                    "name": "DM Sans",
                    "fontFace": [
                        {
                            "fontFamily": "DM Sans",
                            "fontWeight": "500",
                            "fontStyle": "normal",
                            "fontStretch": "normal",
                            "src": [
                                "file:./assets/fonts/dm-sans/dm-sans-v11-latin-500.woff2"
                            ]
                        },
                        {
                            "fontFamily": "DM Sans",
                            "fontWeight": "500",
                            "fontStyle": "italic",
                            "fontStretch": "normal",
                            "src": [
                                "file:./assets/fonts/dm-sans/dm-sans-v11-latin-500italic.woff2"
                            ]
                        },
                        {
                            "fontFamily": "DM Sans",
                            "fontWeight": "700",
                            "fontStyle": "normal",
                            "fontStretch": "normal",
                            "src": [
                                "file:./assets/fonts/dm-sans/dm-sans-v11-latin-700.woff2"
                            ]
                        },
                        {
                            "fontFamily": "DM Sans",
                            "fontWeight": "700",
                            "fontStyle": "italic",
                            "fontStretch": "normal",
                            "src": [
                                "file:./assets/fonts/dm-sans/dm-sans-v11-latin-700italic.woff2"
                            ]
                        }
                    ]
                },
                {
                    "fontFamily": "ui-sans-serif, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", sans-serif",
                    "slug": "system-sans-serif",
                    "name": "System Sans Serif"
                },
                {
                    "fontFamily": "ui-serif, \"Iowan Old Style\", \"Apple Garamond\", Baskerville, \"Times New Roman\", \"Droid Serif\", Times, \"Source Serif Pro\", serif",
                    "slug": "system-serif",
                    "name": "System Serif"
                },
                {
                    "fontFamily": "ui-monospace, Menlo, Consolas, Monaco, \"Liberation Mono\", \"Lucida Console\", monospace",
                    "slug": "system-monospace",
                    "name": "System Monospace"
                }
            ],
            "fontSizes": [
                {
                    "slug": "small",
                    "name": "Small",
                    "size": "0.9rem",
                    "fluid": false
                },
                {
                    "slug": "medium",
                    "name": "Medium",
                    "size": "1.05rem",
                    "fluid": false
                },
                {
                    "slug": "large",
                    "name": "Large",
                    "size": "clamp(1.39rem, calc(1.39rem + ((1vw - 0.32rem) * 0.767)), 1.85rem)",
                    "fluid": {
                        "min": "1.39rem",
                        "max": "1.85rem"
                    }
                },
                {
                    "slug": "x-large",
                    "name": "Extra Large",
                    "size": "clamp(1.85rem, calc(1.85rem + ((1vw - 0.32rem) * 1.083)), 2.5rem)",
                    "fluid": {
                        "min": "1.85rem",
                        "max": "2.5rem"
                    }
                },
                {
                    "slug": "xx-large",
                    "name": "2X Large",
                    "size": "clamp(2.5rem, calc(2.5rem + ((1vw - 0.32rem) * 1.283)), 3.27rem)",
                    "fluid": {
                        "min": "2.5rem",
                        "max": "3.27rem"
                    }
                }
            ]
        },
        "useRootPaddingAwareAlignments": true,
        "shadow": {
            "presets": [
                {
                    "slug": "sm",
                    "name": "Small",
                    "shadow": "0 1px 2px 0 rgba(0, 0, 0, 0.05)"
                },
                {
                    "slug": "md",
                    "name": "Medium",
                    "shadow": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1)"
                },
                {
                    "slug": "lg",
                    "name": "Large",
                    "shadow": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1)"
                },
                {
                    "slug": "xl",
                    "name": "Extra Large",
                    "shadow": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1)"
                }
            ],
            "defaultPresets": true
        }
    },
    "styles": {
        "blocks": {
            "core/buttons": {
                "spacing": {
                    "blockGap": "24px"
                }
            },
            "core/calendar": {
                "color": {
                    "text": "var(--wp--preset--color--foreground)"
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--small)"
                }
            },
            "core/comment-author-name": {
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                }
            },
            "core/comment-edit-link": {
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                }
            },
            "core/comment-date": {
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                }
            },
            "core/comment-reply-link": {
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                }
            },
            "core/cover": {
                "spacing": {
                    "padding": {
                        "bottom": "var(--wp--preset--spacing--60)",
                        "left": "var(--wp--preset--spacing--60)",
                        "right": "var(--wp--preset--spacing--60)",
                        "top": "var(--wp--preset--spacing--60)"
                    }
                }
            },
            "core/file": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--small)",
                    "fontWeight": "700",
                    "lineHeight": "var(--wp--custom--typography--line-height--heading)"
                }
            },
            "core/navigation": {
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                },
                "typography": {
                    "fontWeight": "500"
                }
            },
            "core/paragraph": {
                "typography": {
                    "lineHeight": "var(--wp--custom--typography--line-height--body)"
                }
            },
            "core/post-date": {
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                }
            },
            "core/post-title": {
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                }
            },
            "core/preformatted": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--small)"
                }
            },
            "core/pullquote": {
                "border": {
                    "bottom": {
                        "width": "0"
                    },
                    "top": {
                        "width": "0"
                    }
                },
                "elements": {
                    "cite": {
                        "typography": {
                            "fontSize": "14px",
                            "fontStyle": "normal",
                            "fontWeight": "700",
                            "letterSpacing": "var(--wp--custom--typography--letter-spacing--uppercase)",
                            "textTransform": "uppercase"
                        }
                    }
                },
                "spacing": {
                    "padding": {
                        "bottom": "0px",
                        "left": "0px",
                        "right": "0px",
                        "top": "0px"
                    }
                },
                "typography": {
                    "fontSize": "var( --wp--preset--font-size--extra-large )",
                    "lineHeight": "1.35"
                }
            },
            "core/query-pagination": {
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                }
            },
            "core/quote": {
                "border": {
                    "left": {
                        "color": "currentColor",
                        "style": "solid",
                        "width": "2px"
                    },
                    "radius": "var:preset|spacing|20"
                },
                "elements": {
                    "cite": {
                        "spacing": {
                            "margin": {
                                "bottom": "0",
                                "left": "0",
                                "right": "0",
                                "top": "1em"
                            }
                        }
                    }
                },
                "spacing": {
                    "padding": {
                        "left": "1em"
                    }
                },
                "color": {
                    "background": "var:preset|color|base-2"
                }
            },
            "core/site-tagline": {
                "spacing": {
                    "margin": {
                        "bottom": "0px",
                        "top": "0px"
                    }
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--normal)"
                }
            },
            "core/site-title": {
                "elements": {
                    "link": {
                        ":hover": {
                            "typography": {
                                "textDecoration": "underline"
                            }
                        },
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                },
                "spacing": {
                    "margin": {
                        "bottom": "0px",
                        "top": "0px"
                    }
                },
                "typography": {
                    "fontFamily": "inherit",
                    "fontStyle": "inherit",
                    "fontWeight": "500",
                    "textTransform": "inherit"
                }
            },
            "core/spacer": {
                "spacing": {
                    "margin": {
                        "bottom": "0px",
                        "top": "0px"
                    }
                }
            },
            "core/table": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--small)",
                    "lineHeight": "var(--wp--custom--typography--line-height--body)"
                }
            },
            "core/site-logo": {
                "border": {
                    "radius": "0px"
                }
            },
            "core/button": {
                "border": {
                    "radius": "0px"
                },
                "typography": {
                    "fontWeight": "700",
                    "letterSpacing": "0.02em"
                },
                "color": {
                    "background": "var:preset|color|accent",
                    "text": "var:preset|color|base"
                }
            },
            "core/separator": {
                "color": {
                    "text": "var:preset|color|contrast-3"
                }
            }
        },
        "color": {
            "background": "var:preset|color|base",
            "text": "var:preset|color|contrast"
        },
        "elements": {
            "button": {
                "border": {
                    "color": "currentColor",
                    "radius": "0px",
                    "style": "var(--wp--custom--shaded-style--border--style)",
                    "width": "var(--wp--custom--shaded-style--border--width)"
                },
                "color": {
                    "background": "var:preset|color|accent",
                    "text": "var:preset|color|base"
                },
                "shadow": "var( --wp--custom--shaded-style--box-shadow--x ) var( --wp--custom--shaded-style--box-shadow--y ) var( --wp--custom--shaded-style--box-shadow--blur ) currentColor",
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--small)",
                    "fontWeight": "700",
                    "lineHeight": "var(--wp--custom--typography--line-height--heading)"
                },
                ":hover": {
                    "color": {
                        "background": "var:preset|color|accent-3"
                    }
                },
                ":active": {
                    "color": {
                        "background": "var:preset|color|accent-3"
                    }
                }
            },
            "caption": {
                "color": {
                    "text": "var:preset|color|contrast-2"
                },
                "typography": {
                    "fontSize": "var:preset|font-size|small",
                    "lineHeight": "1.4"
                },
                "spacing": {
                    "margin": {
                        "bottom": "0",
                        "left": "0",
                        "right": "0",
                        "top": "1em"
                    }
                }
            },
            "cite": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--heading-6)",
                    "fontStyle": "normal",
                    "fontWeight": "700",
                    "letterSpacing": "var(--wp--custom--typography--letter-spacing--uppercase)",
                    "textTransform": "uppercase"
                }
            },
            "heading": {
                "spacing": {
                    "margin": {
                        "bottom": ".75em",
                        "top": "1em"
                    }
                },
                "typography": {
                    "fontWeight": "700",
                    "letterSpacing": "var(--wp--custom--typography--letter-spacing--heading)",
                    "lineHeight": "var(--wp--custom--typography--line-height--heading)"
                }
            },
            "h1": {
                "typography": {
                    "fontSize": "var:preset|font-size|xx-large",
                    "lineHeight": "1.15",
                    "letterSpacing": "-0.03em"
                },
                "color": {
                    "text": "var:preset|color|contrast"
                }
            },
            "h2": {
                "typography": {
                    "fontSize": "var:preset|font-size|x-large",
                    "lineHeight": "1.2",
                    "letterSpacing": "-0.01em"
                },
                "color": {
                    "text": "var:preset|color|contrast"
                }
            },
            "h3": {
                "typography": {
                    "fontSize": "var:preset|font-size|large",
                    "lineHeight": "1.25"
                },
                "color": {
                    "text": "var:preset|color|contrast"
                }
            },
            "h4": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--heading-4)",
                    "lineHeight": "1.3"
                },
                "color": {
                    "text": "var:preset|color|contrast"
                }
            },
            "h5": {
                "typography": {
                    "fontSize": "var:preset|font-size|medium",
                    "lineHeight": "1.4"
                },
                "color": {
                    "text": "var:preset|color|contrast"
                }
            },
            "h6": {
                "typography": {
                    "fontSize": "var:preset|font-size|small",
                    "letterSpacing": "var(--wp--custom--typography--letter-spacing--uppercase)",
                    "textTransform": "uppercase",
                    "lineHeight": "1.4"
                },
                "color": {
                    "text": "var:preset|color|contrast"
                }
            },
            "link": {
                ":hover": {
                    "typography": {
                        "textDecoration": "none"
                    },
                    "color": {
                        "text": "var:preset|color|accent-3"
                    }
                },
                "color": {
                    "text": "var:preset|color|accent"
                },
                "typography": {
                    "textDecoration": "underline"
                }
            }
        },
        "spacing": {
            "blockGap": "min(32px, 6.4vw)",
            "padding": {
                "bottom": "var(--wp--preset--spacing--60)",
                "left": "var(--wp--preset--spacing--60)",
                "right": "var(--wp--preset--spacing--60)",
                "top": "var(--wp--preset--spacing--60)"
            }
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--dm-sans)",
            "fontSize": "var:preset|font-size|medium",
            "letterSpacing": "var(--wp--custom--typography--letter-spacing--body)",
            "lineHeight": "1.55"
        }
    },
    "templateParts": [
        {
            "title": "Header",
            "name": "header",
            "area": "header"
        },
        {
