{
  "title": "Modern Contact Page Pattern",
  "description": "Professional contact page with form, info cards, and map placeholder",
  "content": {
    "header_section": "<!-- wp:heading {\"level\":1,\"style\":{\"color\":{\"text\":\"{{primary_color}}\"},\"spacing\":{\"margin\":{\"bottom\":\"20px\"}}}} -->\n<h1 class=\"wp-block-heading\" style=\"color:{{primary_color}};margin-bottom:20px\">{{headline}}</h1>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph {\"style\":{\"spacing\":{\"margin\":{\"bottom\":\"50px\"}}}} -->\n<p style=\"margin-bottom:50px\">{{intro}}</p>\n<!-- /wp:paragraph -->",
    
    "contact_form_section": "<!-- wp:columns {\"style\":{\"spacing\":{\"blockGap\":{\"left\":\"60px\"}}}} -->\n<div class=\"wp-block-columns\" style=\"gap:60px\">\n    <!-- wp:column {\"width\":\"60%\"} -->\n    <div class=\"wp-block-column\" style=\"flex-basis:60%\">\n        <!-- wp:heading {\"level\":2,\"style\":{\"spacing\":{\"margin\":{\"bottom\":\"30px\"}}}} -->\n        <h2 class=\"wp-block-heading\" style=\"margin-bottom:30px\">Get In Touch</h2>\n        <!-- /wp:heading -->\n        \n        <!-- wp:group {\"style\":{\"border\":{\"radius\":\"10px\"},\"spacing\":{\"padding\":{\"top\":\"40px\",\"bottom\":\"40px\",\"left\":\"30px\",\"right\":\"30px\"}},\"color\":{\"background\":\"#f8f9fa\"}}} -->\n        <div class=\"wp-block-group has-background\" style=\"background-color:#f8f9fa;border-radius:10px;padding:40px 30px\">\n            <!-- wp:paragraph -->\n            <p><strong>Name *</strong></p>\n            <!-- /wp:paragraph -->\n            \n            <!-- wp:paragraph {\"style\":{\"border\":{\"radius\":\"5px\"},\"spacing\":{\"padding\":{\"top\":\"12px\",\"bottom\":\"12px\",\"left\":\"15px\",\"right\":\"15px\"}},\"color\":{\"background\":\"#ffffff\"}}} -->\n            <p class=\"has-background\" style=\"background-color:#ffffff;border-radius:5px;padding:12px 15px\">[Your Name]</p>\n            <!-- /wp:paragraph -->\n            \n            <!-- wp:paragraph -->\n            <p><strong>Email *</strong></p>\n            <!-- /wp:paragraph -->\n            \n            <!-- wp:paragraph {\"style\":{\"border\":{\"radius\":\"5px\"},\"spacing\":{\"padding\":{\"top\":\"12px\",\"bottom\":\"12px\",\"left\":\"15px\",\"right\":\"15px\"}},\"color\":{\"background\":\"#ffffff\"}}} -->\n            <p class=\"has-background\" style=\"background-color:#ffffff;border-radius:5px;padding:12px 15px\">[Your Email]</p>\n            <!-- /wp:paragraph -->\n            \n            <!-- wp:paragraph -->\n            <p><strong>Subject</strong></p>\n            <!-- /wp:paragraph -->\n            \n            <!-- wp:paragraph {\"style\":{\"border\":{\"radius\":\"5px\"},\"spacing\":{\"padding\":{\"top\":\"12px\",\"bottom\":\"12px\",\"left\":\"15px\",\"right\":\"15px\"}},\"color\":{\"background\":\"#ffffff\"}}} -->\n            <p class=\"has-background\" style=\"background-color:#ffffff;border-radius:5px;padding:12px 15px\">[Subject]</p>\n            <!-- /wp:paragraph -->\n            \n            <!-- wp:paragraph -->\n            <p><strong>Message *</strong></p>\n            <!-- /wp:paragraph -->\n            \n            <!-- wp:paragraph {\"style\":{\"border\":{\"radius\":\"5px\"},\"spacing\":{\"padding\":{\"top\":\"12px\",\"bottom\":\"40px\",\"left\":\"15px\",\"right\":\"15px\"}},\"color\":{\"background\":\"#ffffff\"}}} -->\n            <p class=\"has-background\" style=\"background-color:#ffffff;border-radius:5px;padding:12px 15px 40px\">[Your Message]</p>\n            <!-- /wp:paragraph -->\n            \n            <!-- wp:buttons -->\n            <div class=\"wp-block-buttons\">\n                <!-- wp:button {\"backgroundColor\":\"custom\",\"style\":{\"color\":{\"background\":\"{{primary_color}}\"},\"border\":{\"radius\":\"25px\"}}} -->\n                <div class=\"wp-block-button\"><a class=\"wp-block-button__link has-custom-background-color has-background\" style=\"background-color:{{primary_color}};color:#ffffff;border-radius:25px\">Send Message</a></div>\n                <!-- /wp:button -->\n            </div>\n            <!-- /wp:buttons -->\n        </div>\n        <!-- /wp:group -->\n    </div>\n    <!-- /wp:column -->\n    \n    <!-- wp:column {\"width\":\"40%\"} -->\n    <div class=\"wp-block-column\" style=\"flex-basis:40%\">\n        <!-- wp:heading {\"level\":2,\"style\":{\"spacing\":{\"margin\":{\"bottom\":\"30px\"}}}} -->\n        <h2 class=\"wp-block-heading\" style=\"margin-bottom:30px\">Contact Information</h2>\n        <!-- /wp:heading -->\n        \n        {{contact_info_cards}}\n    </div>\n    <!-- /wp:column -->\n</div>\n<!-- /wp:columns -->",
    
    "contact_info_card": "<!-- wp:group {\"style\":{\"border\":{\"radius\":\"10px\"},\"spacing\":{\"padding\":{\"top\":\"25px\",\"bottom\":\"25px\",\"left\":\"20px\",\"right\":\"20px\"},\"margin\":{\"bottom\":\"20px\"}},\"color\":{\"background\":\"#ffffff\"},\"border\":{\"width\":\"1px\",\"color\":\"#e0e0e0\"}}} -->\n<div class=\"wp-block-group has-background has-border-color\" style=\"background-color:#ffffff;border-color:#e0e0e0;border-width:1px;border-radius:10px;margin-bottom:20px;padding:25px 20px\">\n    <!-- wp:heading {\"level\":4,\"style\":{\"color\":{\"text\":\"{{primary_color}}\"},\"spacing\":{\"margin\":{\"bottom\":\"10px\"}}}} -->\n    <h4 class=\"wp-block-heading\" style=\"color:{{primary_color}};margin-bottom:10px\">{{info_title}}</h4>\n    <!-- /wp:heading -->\n    \n    <!-- wp:paragraph -->\n    <p>{{info_content}}</p>\n    <!-- /wp:paragraph -->\n</div>\n<!-- /wp:group -->",
    
    "business_hours_section": "<!-- wp:group {\"style\":{\"spacing\":{\"padding\":{\"top\":\"50px\",\"bottom\":\"20px\"}}}} -->\n<div class=\"wp-block-group\" style=\"padding-top:50px;padding-bottom:20px\">\n    <!-- wp:heading {\"level\":2,\"style\":{\"spacing\":{\"margin\":{\"bottom\":\"20px\"}}}} -->\n    <h2 class=\"wp-block-heading\" style=\"margin-bottom:20px\">Business Hours</h2>\n    <!-- /wp:heading -->\n    \n    <!-- wp:paragraph {\"style\":{\"typography\":{\"fontSize\":\"18px\"}}} -->\n    <p style=\"font-size:18px\"><strong>{{hours_text}}</strong></p>\n    <!-- /wp:paragraph -->\n    \n    <!-- wp:paragraph -->\n    <p>{{response_promise}}</p>\n    <!-- /wp:paragraph -->\n</div>\n<!-- /wp:group -->"
  }
}