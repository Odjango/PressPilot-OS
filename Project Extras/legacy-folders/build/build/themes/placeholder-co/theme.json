{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "color": {
      "defaultPalette": false,
      "defaultGradients": false,
      "palette": [
        {
          "slug": "background",
          "color": "#f8fafc",
          "name": "Background"
        },
        {
          "slug": "soft-bg",
          "color": "#ffffff",
          "name": "Soft background"
        },
        {
          "slug": "foreground",
          "color": "#0f172a",
          "name": "Foreground"
        },
        {
          "slug": "muted",
          "color": "#64748b",
          "name": "Muted"
        },
        {
          "slug": "border",
          "color": "#e2e8f0",
          "name": "Border"
        },
        {
          "slug": "primary",
          "color": "#3b82f6",
          "name": "Primary"
        },
        {
          "slug": "accent",
          "color": "#a855f7",
          "name": "Accent"
        },
        {
          "slug": "warning",
          "color": "#f97316",
          "name": "Warning"
        },
        {
          "slug": "success",
          "color": "#22c55e",
          "name": "Success"
        }
      ]
    },
    "layout": {
      "contentSize": "960px",
      "wideSize": "1200px"
    },
    "spacing": {
      "padding": true,
      "margin": true,
      "blockGap": true,
      "units": [
        "px",
        "rem",
        "em",
        "vh",
        "vw",
        "%"
      ],
      "spacingSizes": [
        {
          "slug": "20",
          "size": "0.75rem",
          "name": "20"
        },
        {
          "slug": "30",
          "size": "1.25rem",
          "name": "30"
        },
        {
          "slug": "40",
          "size": "1.75rem",
          "name": "40"
        },
        {
          "slug": "50",
          "size": "2.5rem",
          "name": "50"
        },
        {
          "slug": "60",
          "size": "3.5rem",
          "name": "60"
        }
      ]
    },
    "typography": {
      "dropCap": false,
      "fontFamilies": [
        {
          "slug": "system-sans",
          "name": "System Sans",
          "fontFamily": "-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif"
        }
      ],
      "fontSizes": [
        {
          "slug": "xs",
          "size": "0.85rem",
          "name": "XS"
        },
        {
          "slug": "sm",
          "size": "0.95rem",
          "name": "Small"
        },
        {
          "slug": "base",
          "size": "1rem",
          "name": "Base"
        },
        {
          "slug": "lg",
          "size": "1.25rem",
          "name": "Large"
        },
        {
          "slug": "xl",
          "size": "1.5rem",
          "name": "XL"
        },
        {
          "slug": "xxl",
          "size": "2.25rem",
          "name": "Display"
        }
      ]
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": true
        }
      },
      "core/group": {
        "spacing": {
          "margin": true,
          "padding": true,
          "blockGap": true
        }
      },
      "core/navigation": {
        "spacing": {
          "blockGap": true
        },
        "typography": {
          "fontSize": true
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--foreground)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-sans)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--40)"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--system-sans)",
          "fontWeight": "600",
          "lineHeight": "1.15",
          "fontSize": "clamp(2.5rem, 4vw, 2.9rem)"
        },
        "color": {
          "text": "var(--wp--preset--color--foreground)"
        },
        "spacing": {
          "margin": {
            "bottom": "0.75em"
          }
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        "typography": {
          "textDecoration": "none",
          "fontWeight": "500"
        }
      },
      "button": {
        "border": {
          "radius": "999px"
        },
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--soft-bg)"
        },
        "spacing": {
          "padding": {
            "top": "0.7rem",
            "right": "1.4rem",
            "bottom": "0.7rem",
            "left": "1.4rem"
          }
        },
        "typography": {
          "fontWeight": "700"
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "typography": {
          "fontWeight": "700"
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": "0.95rem",
          "fontWeight": "500"
        },
        "spacing": {
          "blockGap": "1.75rem"
        }
      },
      "core/group": {
        "spacing": {
          "blockGap": "var(--wp--preset--spacing--50)"
        }
      },
      "core/query-pagination": {
        "typography": {
          "fontSize": "0.9rem"
        }
      }
    }
  },
  "custom": {
    "presspilot": {
      "appliedStyleVariation": "saas-bright",
      "businessTypeId": "saas",
      "kitVersion": "0.6.0"
    }
  }
}