{
  "$schema": "https://presspilot.io/pattern-registry.schema.json",
  "version": "1.0.0",
  "description": "PressPilot Pattern Registry - AI uses this to select patterns and generate content",
  
  "templates": {
    "restaurant": {
      "name": "Restaurant",
      "description": "Complete restaurant website with menu, hours, and reservations",
      "suggested_patterns": [
        "headers/centered-logo",
        "heroes/cover-cta",
        "restaurant/menu-categories",
        "restaurant/chef-highlight",
        "testimonials/grid-3",
        "restaurant/hours-location",
        "footers/restaurant"
      ],
      "user_guidance": {
        "reservations": {
          "approach": "static-first",
          "generated_page": "Contact page with phone number and CTA button",
          "enhancement_options": [
            {
              "option": "booking_widget",
              "label": "Booking Widget",
              "description": "Embed a reservation widget from OpenTable, Resy, or SimplyBook.me",
              "effort": "low",
              "services": ["OpenTable", "Resy", "Yelp Reservations", "TableAgent", "SimplyBook.me"]
            },
            {
              "option": "form_plugin",
              "label": "Contact Form Plugin",
              "description": "Add a reservation form using WPForms, Contact Form 7, or Gravity Forms",
              "effort": "medium",
              "plugins": ["WPForms Lite", "Contact Form 7", "Formidable Forms", "Gravity Forms"]
            },
            {
              "option": "phone_only",
              "label": "Phone/Email Only",
              "description": "Keep the generated Contact page as-is with phone number displayed",
              "effort": "none"
            }
          ],
          "edit_location": "Pages > Contact in WordPress admin"
        },
        "ui_tip": "Your theme includes a Contact page where customers can find your phone number and reach out to make a reservation. To accept online bookings, add a reservation widget (OpenTable, Resy) or a WordPress form plugin (WPForms) after installing your theme.",
        "docs": "/docs/business-types/restaurant.md"
      }
    },
    "ecommerce": {
      "name": "E-Commerce Store",
      "description": "Online store with product showcases and categories",
      "suggested_patterns": [
        "headers/ecommerce-cart",
        "heroes/split-image",
        "ecommerce/featured-product",
        "ecommerce/product-grid-4",
        "ecommerce/category-showcase",
        "testimonials/slider",
        "cta/newsletter",
        "footers/ecommerce"
      ]
    },
    "business": {
      "name": "Business / Agency",
      "description": "Professional services and agency website",
      "suggested_patterns": [
        "headers/split-nav",
        "heroes/video-background",
        "features/icon-grid-6",
        "testimonials/carousel",
        "cta/contact-split",
        "footers/business"
      ]
    }
  },

