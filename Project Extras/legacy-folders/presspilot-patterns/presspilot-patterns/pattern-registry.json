  "ai_instructions": {
    "content_generation": {
      "guidelines": [
        "Generate content that matches the business type and tone",
        "Keep titles concise (4-8 words for headlines)",
        "Make descriptions specific to the business, not generic",
        "Use action-oriented language for buttons",
        "Ensure menu prices are realistic for the business type",
        "Generate 3-5 menu items per category for restaurants"
      ],
      "tone_options": ["professional", "casual", "luxurious", "friendly", "playful"],
      "language_support": ["en", "es", "fr", "it", "ar"]
    },
    "pattern_selection": {
      "guidelines": [
        "Choose patterns that match the business type",
        "Ensure visual balance - alternate between content-heavy and visual sections",
        "Always include a header, hero, and footer at minimum",
        "Restaurant sites MUST include menu and hours sections",
        "E-commerce sites MUST include product showcase sections"
      ]
    },
    "output_format": {
      "description": "AI should output JSON matching this structure",
      "example": {
        "selected_patterns": ["headers/centered-logo", "heroes/cover-cta", "restaurant/menu-categories", "footers/restaurant"],
        "strings": {
          "hero/title": "Welcome to Bella Italia",
          "hero/subtitle": "Authentic Italian cuisine in the heart of downtown",
          "menu/category-1-name": "Antipasti"
        },
        "images": {
          "hero/background": "https://images.pexels.com/photos/123456/pexels-photo-123456.jpeg",
          "chef/photo": "https://images.pexels.com/photos/789012/pexels-photo-789012.jpeg"
        },
        "menu_items": [
          {"category": "antipasti", "name": "Bruschetta Classica", "description": "Grilled bread with fresh tomatoes", "price": "$12"}
        ],
        "brand_colors": {
          "primary": "#1e40af",
          "secondary": "#64748b", 
          "accent": "#f59e0b"
        },
        "business": {
          "name": "Bella Italia",
          "tagline": "Authentic Italian Since 1985",
          "phone": "(555) 123-4567",
          "address": "123 Main St, New York, NY 10001"
        }
      }
    }
  }
}
