{
    "name": "High Contrast",
    "slug": "high-contrast",
    "description": "Enhanced contrast for improved accessibility and readability",
    "colors": {
        "primary": "#0f172a",
        "secondary": "#475569",
        "accent": "#dc2626",
        "background": "#ffffff",
        "text": "#000000",
        "surface": "#f1f5f9"
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--base)",
            "text": "var(--wp--preset--color--contrast)"
        },
        "elements": {
            "button": {
                "color": {
                    "background": "var(--wp--preset--color--contrast)",
                    "text": "var(--wp--preset--color--base)"
                },
                "border": {
                    "radius": "0px",
                    "width": "2px",
                    "style": "solid"
                },
                ":hover": {
                    "color": {
                        "background": "var(--wp--preset--color--accent)",
                        "text": "var(--wp--preset--color--base)"
                    }
                }
            },
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--contrast)"
                },
                "typography": {
                    "textDecoration": "underline"
                },
                ":hover": {
                    "color": {
                        "text": "var(--wp--preset--color--accent)"
                    }
                }
            },
            "heading": {
                "color": {
                    "text": "var(--wp--preset--color--contrast)"
                },
                "typography": {
                    "fontWeight": "800"
                }
            }
        },
        "typography": {
            "lineHeight": "1.7"
        },
        "blocks": {
            "core/button": {
                "border": {
                    "radius": "0px",
                    "width": "2px"
                },
                "typography": {
                    "fontWeight": "700",
                    "textTransform": "uppercase",
                    "letterSpacing": "0.05em"
                }
            },
            "core/paragraph": {
                "typography": {
                    "fontSize": "1.125rem"
                }
            }
        }
    },
    "settings": {
        "appearanceTools": true,
        "useRootPaddingAwareAlignments": true
    }
}
