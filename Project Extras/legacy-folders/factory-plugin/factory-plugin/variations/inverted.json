{
    "name": "Inverted",
    "slug": "inverted",
    "description": "Dark mode theme with light text on dark backgrounds",
    "colors": {
        "primary": "#3b82f6",
        "secondary": "#94a3b8",
        "accent": "#fbbf24",
        "background": "#0f172a",
        "text": "#f8fafc",
        "surface": "#1e293b"
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--contrast)",
            "text": "var(--wp--preset--color--base)"
        },
        "elements": {
            "button": {
                "color": {
                    "background": "var(--wp--preset--color--primary)",
                    "text": "var(--wp--preset--color--base)"
                },
                "border": {
                    "radius": "8px"
                },
                ":hover": {
                    "color": {
                        "background": "var(--wp--preset--color--accent)",
                        "text": "var(--wp--preset--color--contrast)"
                    }
                }
            },
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--primary)"
                },
                ":hover": {
                    "color": {
                        "text": "var(--wp--preset--color--accent)"
                    }
                }
            },
            "heading": {
                "color": {
                    "text": "var(--wp--preset--color--base)"
                }
            }
        },
        "blocks": {
            "core/button": {
                "border": {
                    "radius": "8px"
                },
                "color": {
                    "background": "var(--wp--preset--color--primary)",
                    "text": "var(--wp--preset--color--base)"
                }
            },
            "core/group": {
                "color": {
                    "background": "var(--wp--preset--color--surface)"
                }
            },
            "core/cover": {
                "color": {
                    "text": "var(--wp--preset--color--base)"
                }
            }
        }
    },
    "settings": {
        "appearanceTools": true,
        "useRootPaddingAwareAlignments": true
    }
}
