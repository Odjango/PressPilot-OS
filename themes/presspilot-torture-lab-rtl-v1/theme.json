{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "800px",
      "wideSize": "1200px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "base",
          "name": "Base",
          "color": "#f9f9f9"
        },
        {
          "slug": "contrast",
          "name": "Contrast",
          "color": "#1e1e1e"
        },
        {
          "slug": "primary",
          "name": "Primary",
          "color": "#009900"
        },
        {
          "slug": "secondary",
          "name": "Secondary",
          "color": "#ffffff"
        },
        {
          "slug": "muted",
          "name": "Muted",
          "color": "#f0f0f0"
        },
        {
          "slug": "surface",
          "name": "Surface",
          "color": "#fafafa"
        },
        {
          "slug": "border",
          "name": "Border",
          "color": "#e5e5e5"
        }
      ],
      "gradients": [
        {
          "slug": "vertical-brand",
          "gradient": "linear-gradient(to bottom, var(--wp--preset--color--primary) 0%, var(--wp--preset--color--base) 100%)",
          "name": "Vertical Brand"
        },
        {
          "slug": "diagonal-soft",
          "gradient": "linear-gradient(135deg, var(--wp--preset--color--surface) 0%, var(--wp--preset--color--muted) 100%)",
          "name": "Diagonal Soft"
        }
      ]
    },
    "spacing": {
      "spacingSizes": [
        {
          "slug": "xs",
          "name": "XS",
          "size": "0.5rem"
        },
        {
          "slug": "sm",
          "name": "SM",
          "size": "1rem"
        },
        {
          "slug": "md",
          "name": "MD",
          "size": "1.5rem"
        },
        {
          "slug": "lg",
          "name": "LG",
          "size": "2.5rem"
        },
        {
          "slug": "xl",
          "name": "XL",
          "size": "4rem"
        },
        {
          "slug": "xxl",
          "name": "XXL",
          "size": "6rem"
        },
        {
          "slug": "xxxl",
          "name": "XXXL",
          "size": "10rem"
        },
        {
          "slug": "30",
          "name": "Space 30",
          "size": "1.5rem"
        },
        {
          "slug": "40",
          "name": "Space 40",
          "size": "2rem"
        },
        {
          "slug": "50",
          "name": "Space 50",
          "size": "2.5rem"
        },
        {
          "slug": "60",
          "name": "Space 60",
          "size": "3rem"
        },
        {
          "slug": "80",
          "name": "Space 80",
          "size": "4.5rem"
        }
      ],
      "spacingScale": {
        "steps": 0
      }
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "heading",
          "name": "Heading",
          "fontFamily": "Tahoma, Arial, sans-serif"
        },
        {
          "slug": "body",
          "name": "Body",
          "fontFamily": "Tahoma, Arial, sans-serif"
        }
      ],
      "fontSizes": [
        {
          "slug": "xs",
          "name": "XS",
          "size": "0.75rem"
        },
        {
          "slug": "sm",
          "name": "Small",
          "size": "0.875rem"
        },
        {
          "slug": "base",
          "name": "Base",
          "size": "1rem"
        },
        {
          "slug": "md",
          "name": "Medium",
          "size": "1.25rem"
        },
        {
          "slug": "lg",
          "name": "Large",
          "size": "1.5rem"
        },
        {
          "slug": "xl",
          "name": "Extra Large",
          "size": "2.25rem"
        },
        {
          "slug": "xxl",
          "name": "XXL",
          "size": "3rem"
        },
        {
          "slug": "xxxl",
          "name": "XXXL",
          "size": "clamp(3rem, 5vw, 4.5rem)"
        },
        {
          "slug": "small",
          "name": "Small",
          "size": "0.875rem"
        },
        {
          "slug": "medium",
          "name": "Medium",
          "size": "1.25rem"
        },
        {
          "slug": "large",
          "name": "Large",
          "size": "1.5rem"
        },
        {
          "slug": "x-large",
          "name": "X-Large",
          "size": "2.25rem"
        }
      ]
    }
  },
  "styles": {
    "root": {
      "color": {
        "background": "var(--wp--preset--color--base)",
        "text": "var(--wp--preset--color--contrast)"
      },
      "typography": {
        "fontFamily": "Tahoma, Arial, sans-serif",
        "lineHeight": "1.7",
        "fontSize": "var(--wp--preset--font-size--base)"
      },
      "spacing": {
        "blockGap": "var(--wp--preset--spacing--md)"
      }
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        "typography": {
          "textDecoration": "underline"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--secondary)"
          },
          "typography": {
            "textDecoration": "none"
          }
        }
      },
      "button": {
        "border": {
          "radius": "4px"
        },
        "color": {
          "text": "var(--wp--preset--color--base)",
          "background": "var(--wp--preset--color--primary)"
        },
        "spacing": {
          "padding": {
            "top": "var(--wp--preset--spacing--sm)",
            "bottom": "var(--wp--preset--spacing--sm)",
            "left": "var(--wp--preset--spacing--md)",
            "right": "var(--wp--preset--spacing--md)"
          }
        }
      },
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "800",
          "lineHeight": "1.1"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        }
      }
    },
    "blocks": {
      "core/button": {
        "variations": {
          "outline": {
            "border": {
              "width": "2px",
              "style": "solid",
              "color": "var(--wp--preset--color--primary)"
            },
            "color": {
              "background": "transparent",
              "text": "var(--wp--preset--color--primary)"
            }
          }
        }
      },
      "core/navigation-link": {
        "variations": {
          "cta": {
            "color": {
              "background": "var(--wp--preset--color--primary)",
              "text": "var(--wp--preset--color--base)"
            },
            "border": {
              "radius": "4px"
            },
            "spacing": {
              "padding": {
                "top": "0.5rem",
                "bottom": "0.5rem",
                "left": "1rem",
                "right": "1rem"
              }
            }
          }
        }
      }
    }
  }
}