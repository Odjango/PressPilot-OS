{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "720px",
      "wideSize": "1120px"
    },
    "spacing": {
      "units": [
        "px",
        "em",
        "rem",
        "%"
      ],
      "padding": true,
      "margin": true,
      "blockGap": true
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "background",
          "name": "Background",
          "color": "#ffffff"
        },
        {
          "slug": "foreground",
          "name": "Foreground",
          "color": "#1e1e1e"
        },
        {
          "slug": "primary",
          "name": "Primary",
          "color": "#0066cc"
        },
        {
          "slug": "secondary",
          "name": "Secondary",
          "color": "#6c757d"
        },
        {
          "slug": "accent",
          "name": "Accent",
          "color": "#0066cc"
        },
        {
          "slug": "muted",
          "name": "Muted",
          "color": "#f8f9fa"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "system-sans",
          "name": "System Sans",
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif"
        }
      ],
      "fontSizes": [
        {
          "slug": "sm",
          "name": "Small",
          "size": "0.875rem"
        },
        {
          "slug": "base",
          "name": "Base",
          "size": "1rem"
        },
        {
          "slug": "md",
          "name": "Medium",
          "size": "1.25rem"
        },
        {
          "slug": "lg",
          "name": "Large",
          "size": "2.25rem"
        },
        {
          "slug": "xl",
          "name": "Extra Large",
          "size": "3rem"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--foreground)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-sans)",
      "lineHeight": "1.6",
      "fontSize": "var(--wp--preset--font-size--base)"
    },
    "elements": {
      "button": {
        "appearance": "none",
        "border": {
          "radius": "4px"
        },
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--background)"
        },
        "spacing": {
          "padding": {
            "top": "0.75rem",
            "bottom": "0.75rem",
            "left": "1.5rem",
            "right": "1.5rem"
          }
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      }
    },
    "blocks": {
      "core/navigation": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--sm)",
          "fontWeight": "600"
        }
      }
    }
  },
  "templates": [
    {
      "name": "index",
      "title": "Index"
    },
    {
      "name": "page",
      "title": "Page"
    },
    {
      "name": "front-page",
      "title": "Front Page"
    }
  ],
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ]
}