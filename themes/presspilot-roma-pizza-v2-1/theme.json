{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "720px",
      "wideSize": "1120px"
    },
    "spacing": {
      "units": [
        "px",
        "em",
        "rem",
        "%"
      ],
      "padding": true,
      "margin": true
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "base",
          "name": "Base",
          "color": "#f0f0f0"
        },
        {
          "slug": "surface",
          "name": "Surface",
          "color": "#f8f9fa"
        },
        {
          "slug": "contrast",
          "name": "Contrast",
          "color": "#1e1e1e"
        },
        {
          "slug": "primary",
          "name": "Primary",
          "color": "#ff0000"
        },
        {
          "slug": "secondary",
          "name": "Secondary",
          "color": "#ffffff"
        },
        {
          "slug": "tertiary",
          "name": "Tertiary",
          "color": "#f8f9fa"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "system-sans",
          "name": "System Sans",
          "fontFamily": "-apple-system,BlinkMacSystemFont,system-ui,Segoe UI,Roboto,Helvetica,Arial,sans-serif"
        }
      ],
      "fontSizes": [
        {
          "slug": "xs",
          "name": "XS",
          "size": "12px"
        },
        {
          "slug": "sm",
          "name": "Small",
          "size": "14px"
        },
        {
          "slug": "base",
          "name": "Base",
          "size": "16px"
        },
        {
          "slug": "md",
          "name": "Medium",
          "size": "20px"
        },
        {
          "slug": "lg",
          "name": "Large",
          "size": "24px"
        },
        {
          "slug": "xl",
          "name": "XL",
          "size": "32px"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast)"
    },
    "elements": {
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--base)"
        },
        "border": {
          "radius": "999px"
        },
        "spacing": {
          "padding": {
            "top": "0.75rem",
            "bottom": "0.75rem",
            "left": "1.75rem",
            "right": "1.75rem"
          }
        },
        "typography": {
          "fontWeight": "600"
        }
      }
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-sans)",
      "lineHeight": "1.6"
    },
    "layout": {
      "contentSize": "720px",
      "wideSize": "1120px"
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "999px"
        },
        "typography": {
          "fontSize": "var(--wp--preset--font-size--md)"
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--sm)",
          "fontWeight": "500"
        }
      }
    }
  },
  "templates": [
    {
      "name": "index",
      "title": "Blog Index",
      "postTypes": [
        "post"
      ]
    },
    {
      "name": "page",
      "title": "Page",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "front-page",
      "title": "Front Page",
      "postTypes": [
        "page"
      ]
    }
  ],
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ]
}