{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "720px",
      "wideSize": "1120px"
    },
    "spacing": {
      "units": [
        "px",
        "em",
        "rem",
        "%"
      ],
      "padding": true,
      "margin": true
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "background",
          "name": "Background",
          "color": "#F0F0F0"
        },
        {
          "slug": "foreground",
          "name": "Foreground",
          "color": "#111111"
        },
        {
          "slug": "primary",
          "name": "Primary",
          "color": "#0055FF"
        },
        {
          "slug": "accent",
          "name": "Accent",
          "color": "#8dc63f"
        },
        {
          "slug": "muted",
          "name": "Muted",
          "color": "#f5f5f7"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "system-sans",
          "name": "System Sans",
          "fontFamily": "-apple-system,BlinkMacSystemFont,system-ui,Segoe UI,Roboto,Helvetica,Arial,sans-serif"
        }
      ],
      "fontSizes": [
        {
          "slug": "xs",
          "name": "XS",
          "size": "12px"
        },
        {
          "slug": "sm",
          "name": "Small",
          "size": "14px"
        },
        {
          "slug": "base",
          "name": "Base",
          "size": "16px"
        },
        {
          "slug": "md",
          "name": "Medium",
          "size": "20px"
        },
        {
          "slug": "lg",
          "name": "Large",
          "size": "24px"
        },
        {
          "slug": "xl",
          "name": "XL",
          "size": "32px"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--foreground)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-sans)",
      "lineHeight": "1.6"
    },
    "layout": {
      "contentSize": "720px",
      "wideSize": "1120px"
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "999px"
        },
        "typography": {
          "fontSize": "var(--wp--preset--font-size--md)",
          "fontWeight": "600"
        },
        "spacing": {
          "padding": {
            "top": "0.75rem",
            "bottom": "0.75rem",
            "left": "1.5rem",
            "right": "1.5rem"
          }
        },
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "#ffffff"
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--sm)",
          "fontWeight": "500"
        }
      }
    }
  },
  "templates": [
    {
      "name": "index",
      "title": "Blog Index",
      "postTypes": [
        "post"
      ]
    },
    {
      "name": "page",
      "title": "Page",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "front-page",
      "title": "Front Page",
      "postTypes": [
        "page"
      ]
    }
  ],
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ]
}