{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "layout": {
            "contentSize": "800px",
            "wideSize": "1200px"
        },
        "typography": {
            "fontFamilies": [
                {
                    "slug": "system-sans",
                    "name": "System Sans",
                    "fontFamily": "-apple-system,BlinkMacSystemFont,system-ui,sans-serif"
                }
            ]
        }
    },
    "templateParts": [
        {
            "name": "header",
            "title": "Site Header",
            "area": "header"
        },
        {
            "name": "footer",
            "title": "Site Footer",
            "area": "footer"
        }
    ],
    "customTemplates": [
        {
            "name": "page-home",
            "title": "Home Page",
            "postTypes": [
                "page"
            ]
        }
    ]
}