{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "720px",
      "wideSize": "1120px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "base",
          "name": "Base",
          "color": "#f4f4f4"
        },
        {
          "slug": "contrast",
          "name": "Contrast",
          "color": "#1e1e1e"
        },
        {
          "slug": "primary",
          "name": "Primary",
          "color": "#ff4500"
        },
        {
          "slug": "secondary",
          "name": "Secondary",
          "color": "#ffffff"
        },
        {
          "slug": "tertiary",
          "name": "Tertiary",
          "color": "#f8f9fa"
        }
      ]
    },
    "spacing": {
      "spacingSizes": [
        {
          "slug": "xs",
          "name": "Extra Small",
          "size": "0.5rem"
        },
        {
          "slug": "sm",
          "name": "Small",
          "size": "1rem"
        },
        {
          "slug": "md",
          "name": "Medium",
          "size": "1.5rem"
        },
        {
          "slug": "lg",
          "name": "Large",
          "size": "3rem"
        },
        {
          "slug": "xl",
          "name": "Extra Large",
          "size": "5rem"
        }
      ],
      "spacingScale": {
        "steps": 0
      }
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "system-sans",
          "name": "System Sans",
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "name": "Small",
          "size": "clamp(0.875rem, 0.8rem + 0.25vw, 1rem)"
        },
        {
          "slug": "medium",
          "name": "Medium",
          "size": "clamp(1rem, 1rem + 0.5vw, 1.25rem)"
        },
        {
          "slug": "large",
          "name": "Large",
          "size": "clamp(1.75rem, 1.5rem + 1.5vw, 2.5rem)"
        },
        {
          "slug": "x-large",
          "name": "Extra Large",
          "size": "clamp(2.25rem, 1.75rem + 2.5vw, 3.5rem)"
        }
      ]
    }
  },
  "styles": {
    "root": {
      "color": {
        "background": "var(--wp--preset--color--base)",
        "text": "var(--wp--preset--color--contrast)"
      },
      "spacing": {
        "padding": {
          "left": "var(--wp--preset--spacing--md)",
          "right": "var(--wp--preset--spacing--md)"
        }
      },
      "typography": {
        "fontFamily": "var(--wp--preset--font-family--system-sans)",
        "lineHeight": "1.6",
        "fontSize": "var(--wp--preset--font-size--medium)"
      }
    },
    "elements": {
      "button": {
        "appearance": "none",
        "border": {
          "radius": "4px"
        },
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--base)"
        },
        "spacing": {
          "padding": {
            "top": "0.75rem",
            "bottom": "0.75rem",
            "left": "1.5rem",
            "right": "1.5rem"
          }
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--secondary)"
          },
          "typography": {
            "textDecoration": "none"
          }
        }
      }
    },
    "blocks": {
      "core/navigation": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--small)",
          "fontWeight": "600"
        }
      }
    }
  },
  "templates": [
    {
      "name": "index",
      "title": "Index"
    },
    {
      "name": "page",
      "title": "Page"
    },
    {
      "name": "front-page",
      "title": "Front Page"
    },
    {
      "name": "single",
      "title": "Single Post"
    },
    {
      "name": "404",
      "title": "404 Error"
    }
  ],
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ]
}