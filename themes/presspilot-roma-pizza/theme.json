{
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1200px"
    },
    "spacing": {
      "units": [
        "px",
        "em",
        "rem"
      ],
      "spacingScale": {
        "steps": [
          4,
          8,
          12,
          16,
          24,
          32,
          48,
          64
        ]
      }
    },
    "typography": {
      "fontSizes": [
        {
          "slug": "small",
          "size": "14px"
        },
        {
          "slug": "body",
          "size": "16px"
        },
        {
          "slug": "medium",
          "size": "20px"
        },
        {
          "slug": "large",
          "size": "28px"
        },
        {
          "slug": "x-large",
          "size": "42px"
        }
      ],
      "fontWeight": true,
      "lineHeight": true
    },
    "color": {
      "palette": [
        {
          "slug": "base",
          "color": "#111111",
          "name": "Base"
        },
        {
          "slug": "contrast",
          "color": "#000000",
          "name": "Contrast"
        },
        {
          "slug": "primary",
          "color": "#8dc63f",
          "name": "Primary"
        },
        {
          "slug": "secondary",
          "color": "#ffffff",
          "name": "Secondary"
        },
        {
          "slug": "tertiary",
          "color": "#F0F0F0",
          "name": "Tertiary"
        }
      ]
    },
    "blocks": {
      "core/button": {
        "typography": {
          "fontSize": "16px",
          "fontWeight": "600"
        },
        "border": {
          "radius": "6px"
        },
        "spacing": {
          "padding": {
            "top": "12px",
            "bottom": "12px",
            "left": "20px",
            "right": "20px"
          }
        }
      }
    }
  },
  "title": "Roma Pizza",
  "styles": {
    "color": {
      "text": "var(--wp--preset--color--base)",
      "background": "var(--wp--preset--color--secondary)"
    },
    "blocks": {
      "core/button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--secondary)"
        }
      }
    }
  },
  "patterns": [
    "presspilot/home-hero",
    "presspilot/home-services",
    "presspilot/page-about",
    "presspilot/page-services",
    "presspilot/page-contact",
    "presspilot/page-menu"
  ]
}