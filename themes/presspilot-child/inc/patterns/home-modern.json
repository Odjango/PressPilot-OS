{
  "title": "Modern Home Page Pattern",
  "description": "Professional home page with hero, features, testimonials, and CTA sections",
  "content": {
    "hero_section": "<!-- wp:cover {\"url\":\"{{hero_image}}\",\"dimRatio\":50,\"minHeight\":500,\"className\":\"hero-section\"} -->\n<div class=\"wp-block-cover hero-section\" style=\"min-height:500px\">\n    <span aria-hidden=\"true\" class=\"wp-block-cover__background has-background-dim\"></span>\n    <img class=\"wp-block-cover__image-background\" alt=\"\" src=\"{{hero_image}}\" data-object-fit=\"cover\"/>\n    <div class=\"wp-block-cover__inner-container\">\n        <!-- wp:heading {\"level\":1,\"fontSize\":\"huge\",\"style\":{\"color\":{\"text\":\"#ffffff\"}}} -->\n        <h1 class=\"wp-block-heading has-huge-font-size\" style=\"color:#ffffff\">{{hero_headline}}</h1>\n        <!-- /wp:heading -->\n        \n        <!-- wp:paragraph {\"fontSize\":\"large\",\"style\":{\"color\":{\"text\":\"#ffffff\"}}} -->\n        <p class=\"has-large-font-size\" style=\"color:#ffffff\">{{hero_subheadline}}</p>\n        <!-- /wp:paragraph -->\n        \n        <!-- wp:buttons -->\n        <div class=\"wp-block-buttons\">\n            <!-- wp:button {\"backgroundColor\":\"custom\",\"style\":{\"color\":{\"background\":\"{{primary_color}}\"}}} -->\n            <div class=\"wp-block-button\"><a class=\"wp-block-button__link has-custom-background-color has-background\" style=\"background-color:{{primary_color}};color:#ffffff\">{{cta_text}}</a></div>\n            <!-- /wp:button -->\n        </div>\n        <!-- /wp:buttons -->\n    </div>\n</div>\n<!-- /wp:cover -->",
    "features_section": "<!-- wp:group {\"style\":{\"spacing\":{\"padding\":{\"top\":\"60px\",\"bottom\":\"60px\"}}}} -->\n<div class=\"wp-block-group\" style=\"padding-top:60px;padding-bottom:60px\">\n    <!-- wp:heading {\"textAlign\":\"center\",\"style\":{\"spacing\":{\"margin\":{\"bottom\":\"50px\"}}}} -->\n    <h2 class=\"wp-block-heading has-text-align-center\" style=\"margin-bottom:50px\">Why Choose Us</h2>\n    <!-- /wp:heading -->\n    \n    <!-- wp:columns {\"style\":{\"spacing\":{\"blockGap\":{\"left\":\"40px\"}}}} -->\n    <div class=\"wp-block-columns\" style=\"gap:40px\">{{features_columns}}</div>\n    <!-- /wp:columns -->\n</div>\n<!-- /wp:group -->",
    "feature_column": "<!-- wp:column -->\n<div class=\"wp-block-column\">\n    <!-- wp:group {\"style\":{\"border\":{\"radius\":\"10px\"},\"spacing\":{\"padding\":{\"top\":\"30px\",\"bottom\":\"30px\",\"left\":\"25px\",\"right\":\"25px\"}},\"color\":{\"background\":\"#f8f9fa\"}}} -->\n    <div class=\"wp-block-group has-background\" style=\"background-color:#f8f9fa;border-radius:10px;padding:30px 25px\">\n        <!-- wp:paragraph {\"align\":\"center\",\"fontSize\":\"large\",\"style\":{\"color\":{\"text\":\"{{primary_color}}\"}}} -->\n        <p class=\"has-text-align-center has-large-font-size\" style=\"color:{{primary_color}}\">✓</p>\n        <!-- /wp:paragraph -->\n        \n        <!-- wp:heading {\"level\":3,\"textAlign\":\"center\",\"fontSize\":\"medium\"} -->\n        <h3 class=\"wp-block-heading has-text-align-center has-medium-font-size\">{{benefit_title}}</h3>\n        <!-- /wp:heading -->\n        \n        <!-- wp:paragraph {\"textAlign\":\"center\"} -->\n        <p class=\"has-text-align-center\">{{benefit_description}}</p>\n        <!-- /wp:paragraph -->\n    </div>\n    <!-- /wp:group -->\n</div>\n<!-- /wp:column -->",
    "testimonials_section": "<!-- wp:group {\"style\":{\"color\":{\"background\":\"#f8f9fa\"},\"spacing\":{\"padding\":{\"top\":\"60px\",\"bottom\":\"60px\"}}}} -->\n<div class=\"wp-block-group has-background\" style=\"background-color:#f8f9fa;padding-top:60px;padding-bottom:60px\">\n    <!-- wp:heading {\"textAlign\":\"center\",\"style\":{\"spacing\":{\"margin\":{\"bottom\":\"50px\"}}}} -->\n    <h2 class=\"wp-block-heading has-text-align-center\" style=\"margin-bottom:50px\">What Our Clients Say</h2>\n    <!-- /wp:heading -->\n    \n    <!-- wp:columns -->\n    <div class=\"wp-block-columns\">{{testimonial_columns}}</div>\n    <!-- /wp:columns -->\n</div>\n<!-- /wp:group -->",
    "testimonial_column": "<!-- wp:column -->\n<div class=\"wp-block-column\">\n    <!-- wp:group {\"style\":{\"border\":{\"radius\":\"10px\"},\"spacing\":{\"padding\":{\"top\":\"30px\",\"bottom\":\"30px\",\"left\":\"25px\",\"right\":\"25px\"}},\"color\":{\"background\":\"#ffffff\"}}} -->\n    <div class=\"wp-block-group has-background\" style=\"background-color:#ffffff;border-radius:10px;padding:30px 25px\">\n        <!-- wp:paragraph {\"style\":{\"typography\":{\"fontSize\":\"18px\"}}} -->\n        <p style=\"font-size:18px\">\"{{testimonial_text}}\"</p>\n        <!-- /wp:paragraph -->\n        \n        <!-- wp:paragraph {\"style\":{\"color\":{\"text\":\"{{primary_color}}\"},\"typography\":{\"fontWeight\":\"600\"}}} -->\n        <p style=\"color:{{primary_color}};font-weight:600\">— {{customer_name}}</p>\n        <!-- /wp:paragraph -->\n    </div>\n    <!-- /wp:group -->\n</div>\n<!-- /wp:column -->",
    "cta_section": "<!-- wp:group {\"style\":{\"color\":{\"background\":\"{{primary_color}}\"},\"spacing\":{\"padding\":{\"top\":\"60px\",\"bottom\":\"60px\"}}}} -->\n<div class=\"wp-block-group has-background\" style=\"background-color:{{primary_color}};padding-top:60px;padding-bottom:60px\">\n    <!-- wp:heading {\"textAlign\":\"center\",\"style\":{\"color\":{\"text\":\"#ffffff\"},\"spacing\":{\"margin\":{\"bottom\":\"20px\"}}}} -->\n    <h2 class=\"wp-block-heading has-text-align-center has-text-color\" style=\"color:#ffffff;margin-bottom:20px\">Ready to Get Started?</h2>\n    <!-- /wp:heading -->\n    \n    <!-- wp:paragraph {\"textAlign\":\"center\",\"style\":{\"color\":{\"text\":\"#ffffff\"},\"spacing\":{\"margin\":{\"bottom\":\"30px\"}}}} -->\n    <p class=\"has-text-align-center has-text-color\" style=\"color:#ffffff;margin-bottom:30px\">{{cta_description}}</p>\n    <!-- /wp:paragraph -->\n    \n    <!-- wp:buttons {\"layout\":{\"type\":\"flex\",\"justifyContent\":\"center\"}} -->\n    <div class=\"wp-block-buttons\">\n        <!-- wp:button {\"backgroundColor\":\"white\",\"textColor\":\"dark\",\"style\":{\"border\":{\"radius\":\"25px\"}}} -->\n        <div class=\"wp-block-button\"><a class=\"wp-block-button__link has-white-background-color has-dark-color has-text-color has-background\" style=\"border-radius:25px\">{{cta_button_text}}</a></div>\n        <!-- /wp:button -->\n    </div>\n    <!-- /wp:buttons -->\n</div>\n<!-- /wp:group -->"
  }
}