{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "color": {
      "defaultPalette": false,
      "defaultGradients": false,
      "palette": [
        {
          "slug": "background",
          "color": "#f5f5f7",
          "name": "Background"
        },
        {
          "slug": "soft-bg",
          "color": "#ffffff",
          "name": "Soft background"
        },
        {
          "slug": "foreground",
          "color": "#111827",
          "name": "Foreground"
        },
        {
          "slug": "muted",
          "color": "#6b7280",
          "name": "Muted"
        },
        {
          "slug": "border",
          "color": "#e5e7eb",
          "name": "Border"
        },
        {
          "slug": "primary",
          "color": "#2563eb",
          "name": "Primary"
        },
        {
          "slug": "accent",
          "color": "#14b8a6",
          "name": "Accent"
        },
        {
          "slug": "warning",
          "color": "#f97316",
          "name": "Warning"
        },
        {
          "slug": "success",
          "color": "#22c55e",
          "name": "Success"
        }
      ]
    },
    "layout": {
      "contentSize": "960px",
      "wideSize": "1200px"
    },
    "spacing": {
      "padding": true,
      "margin": true,
      "blockGap": true,
      "units": [
        "px",
        "rem",
        "em",
        "vh",
        "vw",
        "%"
      ],
      "spacingSizes": [
        {
          "slug": "20",
          "size": "0.75rem",
          "name": "20"
        },
        {
          "slug": "30",
          "size": "1.25rem",
          "name": "30"
        },
        {
          "slug": "40",
          "size": "1.75rem",
          "name": "40"
        },
        {
          "slug": "50",
          "size": "2.5rem",
          "name": "50"
        },
        {
          "slug": "60",
          "size": "3.5rem",
          "name": "60"
        }
      ]
    },
    "typography": {
      "dropCap": false,
      "fontFamilies": [
        {
          "slug": "system-sans",
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif",
          "name": "System Sans"
        },
        {
          "slug": "system-mono",
          "fontFamily": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace",
          "name": "System Mono"
        },
        {
          "slug": "serif-display",
          "fontFamily": "'Playfair Display', 'Times New Roman', serif",
          "name": "Serif Display"
        }
      ],
      "fontSizes": [
        {
          "slug": "xs",
          "size": "clamp(0.75rem, 0.7rem + 0.25vw, 0.875rem)",
          "name": "XS"
        },
        {
          "slug": "sm",
          "size": "clamp(0.875rem, 0.8rem + 0.375vw, 1rem)",
          "name": "Small"
        },
        {
          "slug": "base",
          "size": "clamp(1rem, 0.95rem + 0.25vw, 1.125rem)",
          "name": "Base"
        },
        {
          "slug": "lg",
          "size": "clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem)",
          "name": "Large"
        },
        {
          "slug": "xl",
          "size": "clamp(1.75rem, 1.5rem + 1.25vw, 2.25rem)",
          "name": "XL"
        },
        {
          "slug": "xxl",
          "size": "clamp(2.5rem, 2.1rem + 2vw, 3.5rem)",
          "name": "Display"
        }
      ]
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": true
        }
      },
      "core/group": {
        "spacing": {
          "margin": true,
          "padding": true,
          "blockGap": true
        }
      },
      "core/navigation": {
        "spacing": {
          "blockGap": true
        },
        "typography": {
          "customFontSize": true
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--foreground)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-sans)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--40)"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--system-sans)",
          "fontWeight": "700",
          "lineHeight": "1.15"
        },
        "color": {
          "text": "var(--wp--preset--color--foreground)"
        },
        "spacing": {
          "margin": {
            "bottom": "0.75em"
          }
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        "typography": {
          "textDecoration": "none",
          "fontWeight": "500"
        }
      },
      "button": {
        "border": {
          "radius": "999px"
        },
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--soft-bg)"
        },
        "spacing": {
          "padding": {
            "top": "0.7rem",
            "right": "1.4rem",
            "bottom": "0.7rem",
            "left": "1.4rem"
          }
        },
        "typography": {
          "fontWeight": "600"
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "typography": {
          "fontWeight": "700"
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": "0.95rem",
          "fontWeight": "500"
        },
        "spacing": {
          "blockGap": "1.75rem"
        }
      },
      "core/group": {
        "spacing": {
          "blockGap": "var(--wp--preset--spacing--40)"
        }
      }
    }
  }
}