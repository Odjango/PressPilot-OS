{
    "name": "Original",
    "slug": "original",
    "description": "Default color scheme with balanced contrast and professional appearance",
    "colors": {
        "primary": "#1e40af",
        "secondary": "#64748b",
        "accent": "#f59e0b",
        "background": "#ffffff",
        "text": "#1f2937",
        "surface": "#f8fafc"
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--base)",
            "text": "var(--wp--preset--color--contrast)"
        },
        "elements": {
            "button": {
                "color": {
                    "background": "var(--wp--preset--color--primary)",
                    "text": "var(--wp--preset--color--base)"
                },
                "border": {
                    "radius": "6px"
                },
                ":hover": {
                    "color": {
                        "background": "var(--wp--preset--color--contrast)"
                    }
                }
            },
            "link": {
                "color": {
                    "text": "var(--wp--preset--color--primary)"
                },
                ":hover": {
                    "color": {
                        "text": "var(--wp--preset--color--contrast)"
                    }
                }
            },
            "heading": {
                "color": {
                    "text": "var(--wp--preset--color--contrast)"
                }
            }
        },
        "blocks": {
            "core/button": {
                "border": {
                    "radius": "6px"
                }
            }
        }
    },
    "settings": {
        "appearanceTools": true,
        "useRootPaddingAwareAlignments": true
    }
}
