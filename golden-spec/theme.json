{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "layout": {
            "contentSize": "720px",
            "wideSize": "1120px"
        },
        "spacing": {
            "spacingScale": {
                "steps": 6
            },
            "units": [
                "px",
                "em",
                "rem",
                "%"
            ],
            "padding": true,
            "margin": true
        },
        "border": {
            "radius": [
                {
                    "slug": "none",
                    "name": "None",
                    "radius": "0"
                },
                {
                    "slug": "sm",
                    "name": "Small",
                    "radius": "0.25rem"
                },
                {
                    "slug": "md",
                    "name": "Medium",
                    "radius": "0.5rem"
                },
                {
                    "slug": "lg",
                    "name": "Large",
                    "radius": "1rem"
                },
                {
                    "slug": "full",
                    "name": "Full",
                    "radius": "9999px"
                }
            ],
            "color": true,
            "style": true,
            "width": true
        },
        "color": {
            "defaultPalette": false,
            "palette": [
                {
                    "slug": "background",
                    "name": "Background",
                    "color": "#ffffff"
                },
                {
                    "slug": "foreground",
                    "name": "Foreground",
                    "color": "#1e293b"
                },
                {
                    "slug": "primary",
                    "name": "Primary",
                    "color": "#2563eb"
                },
                {
                    "slug": "secondary",
                    "name": "Secondary",
                    "color": "#475569"
                },
                {
                    "slug": "accent",
                    "name": "Accent",
                    "color": "#0f172a"
                },
                {
                    "slug": "muted",
                    "name": "Muted",
                    "color": "#f1f5f9"
                }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "slug": "system-sans",
                    "name": "System Sans",
                    "fontFamily": "-apple-system,BlinkMacSystemFont,system-ui,Segoe UI,Roboto,Helvetica,Arial,sans-serif"
                }
            ],
            "fontSizes": [
                {
                    "slug": "xs",
                    "name": "XS",
                    "size": "0.75rem"
                },
                {
                    "slug": "sm",
                    "name": "Small",
                    "size": "0.875rem"
                },
                {
                    "slug": "base",
                    "name": "Base",
                    "size": "1rem"
                },
                {
                    "slug": "md",
                    "name": "Medium",
                    "size": "1.125rem"
                },
                {
                    "slug": "lg",
                    "name": "Large",
                    "size": "1.5rem"
                },
                {
                    "slug": "xl",
                    "name": "XL",
                    "size": "2rem"
                },
                {
                    "slug": "xxl",
                    "name": "XXL",
                    "size": "3rem"
                }
            ]
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--background)",
            "text": "var(--wp--preset--color--foreground)"
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--system-sans)",
            "lineHeight": "1.6",
            "fontSize": "var(--wp--preset--font-size--base)"
        },
        "layout": {
            "contentSize": "720px",
            "wideSize": "1120px"
        },
        "elements": {
            "heading": {
                "typography": {
                    "fontWeight": "700",
                    "lineHeight": "1.2"
                }
            },
            "button": {
                "border": {
                    "radius": "var(--wp--preset--border-radius--md)"
                },
                "typography": {
                    "fontWeight": "600"
                },
                "spacing": {
                    "padding": {
                        "top": "0.75rem",
                        "bottom": "0.75rem",
                        "left": "1.5rem",
                        "right": "1.5rem"
                    }
                },
                "color": {
                    "background": "var(--wp--preset--color--primary)",
                    "text": "#ffffff"
                }
            }
        },
        "blocks": {
            "core/site-title": {
                "typography": {
                    "fontWeight": "700",
                    "textDecoration": "none"
                },
                "elements": {
                    "link": {
                        "typography": {
                            "textDecoration": "none"
                        }
                    }
                }
            },
            "core/post-title": {
                "typography": {
                    "fontWeight": "700"
                }
            },
            "core/navigation": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--sm)",
                    "fontWeight": "500"
                }
            }
        }
    },
    "templates": [
        {
            "name": "index",
            "title": "Blog Index",
            "postTypes": [
                "post"
            ]
        },
        {
            "name": "page",
            "title": "Page",
            "postTypes": [
                "page"
            ]
        },
        {
            "name": "front-page",
            "title": "Front Page",
            "postTypes": [
                "page"
            ]
        }
    ],
    "templateParts": [
        {
            "name": "header",
            "title": "Header",
            "area": "header"
        },
        {
            "name": "footer",
            "title": "Footer",
            "area": "footer"
        }
    ]
}