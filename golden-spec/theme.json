{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "layout": {
            "contentSize": "720px",
            "wideSize": "1120px"
        },
        "spacing": {
            "units": [
                "px",
                "em",
                "rem",
                "%"
            ],
            "padding": true,
            "margin": true,
            "spacingSizes": [
                {
                    "slug": "30",
                    "size": "clamp(1.5rem, 5vw, 2rem)",
                    "name": "Step 30"
                },
                {
                    "slug": "40",
                    "size": "clamp(2rem, 6vw, 2.5rem)",
                    "name": "Step 40"
                },
                {
                    "slug": "50",
                    "size": "clamp(2.5rem, 7vw, 3rem)",
                    "name": "Step 50"
                },
                {
                    "slug": "60",
                    "size": "clamp(3rem, 8vw, 3.5rem)",
                    "name": "Step 60"
                },
                {
                    "slug": "80",
                    "size": "clamp(4rem, 10vw, 5rem)",
                    "name": "Step 80"
                }
            ]
        },
        "color": {
            "defaultPalette": false,
            "palette": [
                {
                    "slug": "base",
                    "name": "Base",
                    "color": "#ffffff"
                },
                {
                    "slug": "surface",
                    "name": "Surface",
                    "color": "#f8f9fa"
                },
                {
                    "slug": "contrast",
                    "name": "Contrast",
                    "color": "#111111"
                },
                {
                    "slug": "primary",
                    "name": "Primary",
                    "color": "#cf2e2e"
                },
                {
                    "slug": "secondary",
                    "name": "Secondary",
                    "color": "#636363"
                },
                {
                    "slug": "tertiary",
                    "name": "Tertiary",
                    "color": "#A4A4A4"
                }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "slug": "system-sans",
                    "name": "System Sans",
                    "fontFamily": "-apple-system,BlinkMacSystemFont,system-ui,Segoe UI,Roboto,Helvetica,Arial,sans-serif"
                }
            ],
            "fontSizes": [
                {
                    "slug": "xs",
                    "name": "XS",
                    "size": "12px"
                },
                {
                    "slug": "sm",
                    "name": "Small",
                    "size": "14px"
                },
                {
                    "slug": "base",
                    "name": "Base",
                    "size": "16px"
                },
                {
                    "slug": "md",
                    "name": "Medium",
                    "size": "20px"
                },
                {
                    "slug": "lg",
                    "name": "Large",
                    "size": "24px"
                },
                {
                    "slug": "xl",
                    "name": "XL",
                    "size": "32px"
                }
            ]
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--base)",
            "text": "var(--wp--preset--color--contrast)"
        },
        "elements": {
            "button": {
                "color": {
                    "background": "var(--wp--preset--color--primary)",
                    "text": "var(--wp--preset--color--base)"
                },
                "border": {
                    "radius": "999px"
                },
                "spacing": {
                    "padding": {
                        "top": "0.75rem",
                        "bottom": "0.75rem",
                        "left": "1.75rem",
                        "right": "1.75rem"
                    }
                },
                "typography": {
                    "fontWeight": "600"
                }
            }
        },
        "typography": {
            "fontFamily": "var(--wp--preset--font-family--system-sans)",
            "lineHeight": "1.6"
        },
        "layout": {
            "contentSize": "720px",
            "wideSize": "1120px"
        },
        "blocks": {
            "core/button": {
                "border": {
                    "radius": "999px"
                },
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--md)"
                }
            },
            "core/navigation": {
                "typography": {
                    "fontSize": "var(--wp--preset--font-size--sm)",
                    "fontWeight": "500"
                }
            }
        }
    },
    "templates": [
        {
            "name": "index",
            "title": "Blog Index",
            "postTypes": [
                "post"
            ]
        },
        {
            "name": "page",
            "title": "Page",
            "postTypes": [
                "page"
            ]
        },
        {
            "name": "front-page",
            "title": "Front Page",
            "postTypes": [
                "page"
            ]
        }
    ],
    "templateParts": [
        {
            "name": "header",
            "title": "Header",
            "area": "header"
        },
        {
            "name": "footer",
            "title": "Footer",
            "area": "footer"
        }
    ]
}