# PressPilot v2 - Docker Environment Variables
# Copy this file to .env and customize as needed

# MySQL Configuration
MYSQL_ROOT_PASSWORD=presspilot_root_secret
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress_secret

# WordPress Configuration
WP_PORT=8080
WORDPRESS_DEBUG=false
WORDPRESS_URL=http://localhost:8080

# WordPress Admin (first-time setup)
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=admin@presspilot.local

# PressPilot API Key (optional - leave empty to disable auth)
# Generate with: openssl rand -hex 32
PRESSPILOT_API_KEY=

# Production settings (uncomment for production)
# WORDPRESS_DEBUG=false
# WP_ADMIN_PASSWORD=your_secure_password_here
# PRESSPILOT_API_KEY=your_api_key_here
