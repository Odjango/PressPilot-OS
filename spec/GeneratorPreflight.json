{
    "schema_version": "1.1",
    "required_fields": [
        "theme_name",
        "theme_slug",
        "site_title",
        "colors",
        "destructive_mode"
    ],
    "capability_fields": {
        "language": {
            "type": "string",
            "example": "ar"
        },
        "direction": {
            "type": "enum",
            "values": [
                "ltr",
                "rtl"
            ]
        },
        "darkMode": {
            "type": "boolean"
        },
        "ecommerce": {
            "type": "boolean"
        },
        "businessType": {
            "type": "enum",
            "values": [
                "restaurant",
                "dentist",
                "generic"
            ]
        },
        "nav_structure": {
            "type": "array"
        }
    },
    "constraints": {
        "acf_enabled": "Must be explicitly true in Task Brief",
        "no_external_requests": true,
        "frozen_timestamp": true
    }
}