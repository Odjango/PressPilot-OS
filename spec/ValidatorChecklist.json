{
    "validator_version": "1.1",
    "hard_rules": {
        "block_closure": {
            "enabled": true,
            "description": "Blocks must be balanced."
        },
        "navigation_ref_ban": {
            "enabled": true,
            "description": "No 'ref' attributes in nav blocks."
        },
        "preset_enforcement": {
            "enabled": true,
            "description": "No raw values where presets exist."
        },
        "undefined_vars": {
            "enabled": true,
            "description": "No references to undefined CSS variables."
        },
        "acf_misuse_detection": {
            "enabled": true,
            "description": "No ACF tokens in templates."
        },
        "malformed_json": {
            "enabled": true,
            "description": "Block comments must be valid JSON."
        },
        "capability_checks": {
            "rtl_dir": {
                "enabled": true,
                "description": "Static HTML must have dir=rtl if requested."
            },
            "dark_mode_parity": {
                "enabled": true,
                "description": "Static data-theme=dark and styles/dark.json must exist."
            },
            "ecom_patterns": {
                "enabled": true,
                "description": "Shop patterns must exist if ecom claimed."
            }
        }
    },
    "test_cases": {
        "negative": [
            {
                "id": "neg_ref",
                "desc": "Nav with ref",
                "snippet": "ref:123",
                "must_fail": true
            },
            {
                "id": "neg_json",
                "desc": "Malformed JSON",
                "snippet": "{unbalanced",
                "must_fail": true
            },
            {
                "id": "neg_acf",
                "desc": "ACF in HTML",
                "snippet": "{{ acf.x }}",
                "must_fail": true
            },
            {
                "id": "neg_var",
                "desc": "Undefined Var",
                "snippet": "var(--missing)",
                "must_fail": true
            }
        ],
        "positive": [
            {
                "id": "pos_nav",
                "desc": "Inline Nav",
                "must_pass": true
            },
            {
                "id": "pos_dark",
                "desc": "Dark Mode Setup",
                "must_pass": true
            }
        ]
    }
}