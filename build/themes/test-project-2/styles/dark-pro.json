{
  "title": "Dark Pro",
  "slug": "dark-pro",
  "$schema": "https://schemas.wp.org/wp/6.4/theme.json",
  "version": 2,
  "settings": {
    "color": {
      "palette": [
        { "slug": "background", "color": "#020617", "name": "Background" },
        { "slug": "soft-bg", "color": "#020617", "name": "Soft background" },
        { "slug": "foreground", "color": "#cbd5f5", "name": "Foreground" },
        { "slug": "muted", "color": "#94a3b8", "name": "Muted" },
        { "slug": "border", "color": "#1f2937", "name": "Border" },
        { "slug": "primary", "color": "#6366f1", "name": "Primary" },
        { "slug": "accent", "color": "#22d3ee", "name": "Accent" },
        { "slug": "warning", "color": "#fb923c", "name": "Warning" },
        { "slug": "success", "color": "#22c55e", "name": "Success" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--foreground)"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "#ffffff"
        }
      },
      "button": {
        "border": {
          "color": "var(--wp--preset--color--accent)",
          "width": "1px",
          "radius": "999px"
        },
        "color": {
          "background": "transparent",
          "text": "var(--wp--preset--color--accent)"
        },
        "typography": {
          "fontWeight": "600"
        },
        "states": {
          "hover": {
            "color": {
              "background": "var(--wp--preset--color--accent)",
              "text": "#020617"
            }
          }
        }
      }
    },
    "blocks": {
      "core/navigation": {
        "color": {
          "text": "#ffffff"
        }
      }
    }
  }
}
